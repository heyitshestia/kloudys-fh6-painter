<UserControl x:Class="KFPS.Wpf.Theming.NightBlossomBackdrop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False"
             Focusable="False"
             ClipToBounds="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="BackdropWindowGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF170D14" Offset="0"/>
            <GradientStop Color="#FF2B1420" Offset="0.50"/>
            <GradientStop Color="#FF3B1729" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BackdropPetalBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FFF3F7" Offset="0"/>
            <GradientStop Color="#E8FF88B6" Offset="0.58"/>
            <GradientStop Color="#D8FF5594" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BackdropBranchBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#CC3B1729" Offset="0"/>
            <GradientStop Color="#D85C2440" Offset="0.56"/>
            <GradientStop Color="#C87A3150" Offset="1"/>
        </LinearGradientBrush>

        <ControlTemplate x:Key="BlossomTemplate" TargetType="ContentControl">
            <Grid Width="34" Height="34" RenderTransformOrigin="0.5,0.5">
                <Ellipse Width="10" Height="18" Fill="{StaticResource BackdropPetalBrush}" Margin="0,0,0,13" RenderTransformOrigin="0.5,1">
                    <Ellipse.RenderTransform><RotateTransform Angle="0"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="10" Height="18" Fill="{StaticResource BackdropPetalBrush}" Margin="0,0,0,13" RenderTransformOrigin="0.5,1">
                    <Ellipse.RenderTransform><RotateTransform Angle="72"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="10" Height="18" Fill="{StaticResource BackdropPetalBrush}" Margin="0,0,0,13" RenderTransformOrigin="0.5,1">
                    <Ellipse.RenderTransform><RotateTransform Angle="144"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="10" Height="18" Fill="{StaticResource BackdropPetalBrush}" Margin="0,0,0,13" RenderTransformOrigin="0.5,1">
                    <Ellipse.RenderTransform><RotateTransform Angle="216"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="10" Height="18" Fill="{StaticResource BackdropPetalBrush}" Margin="0,0,0,13" RenderTransformOrigin="0.5,1">
                    <Ellipse.RenderTransform><RotateTransform Angle="288"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="7" Height="7" Fill="#FFFFC86F" Stroke="#996F2948" StrokeThickness="1"/>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="PetalTemplate" TargetType="ContentControl">
            <Grid Width="20" Height="14">
                <Path Data="M 1,7 C 3,1 11,-1 19,4 C 16,11 8,15 1,7 Z"
                      Fill="{StaticResource BackdropPetalBrush}"
                      Stroke="#40FF88B6"
                      StrokeThickness="0.7"
                      Stretch="Fill"/>
                <Path Data="M 10,2 C 10,5 10,8 9,12" Stroke="#50FF5594" StrokeThickness="0.7"/>
            </Grid>
        </ControlTemplate>

        <Storyboard x:Key="AmbientMotion">
            <DoubleAnimation Storyboard.TargetName="BranchRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-0.18" To="0.24"
                             Duration="0:0:8"
                             AutoReverse="True"
                             RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>


<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Night Blossom is the active native shell material set. -->
    <Color x:Key="Sakura.Background">#FF171116</Color>
    <Color x:Key="Sakura.BackgroundAlt">#FF21131B</Color>
    <Color x:Key="Sakura.Surface">#C4271B23</Color>
    <Color x:Key="Sakura.SurfaceSoft">#9639222F</Color>
    <Color x:Key="Sakura.SurfaceStrong">#D82E1F28</Color>
    <Color x:Key="Sakura.GlassHighlight">#42FFFFFF</Color>
    <Color x:Key="Sakura.Danger">#FFC93762</Color>
    <Color x:Key="Sakura.Branch">#FF6C334A</Color>
    <Color x:Key="Sakura.Border">#3DFFB8D3</Color>
    <Color x:Key="Sakura.BorderStrong">#63FFB8D3</Color>
    <Color x:Key="Sakura.Text">#FFFFF1F6</Color>
    <Color x:Key="Sakura.TextMuted">#FFC9AEB9</Color>
    <Color x:Key="Sakura.TextSubtle">#FF967B86</Color>
    <Color x:Key="Sakura.Primary">#FFFF6B9D</Color>
    <Color x:Key="Sakura.PrimaryLight">#FFFF9ABD</Color>
    <Color x:Key="Sakura.PrimaryDeep">#FFFF4D8B</Color>
    <Color x:Key="Sakura.PrimarySoft">#2EFF5D94</Color>
    <Color x:Key="Sakura.Success">#FF248264</Color>

    <SolidColorBrush x:Key="SakuraBackgroundBrush" Color="{StaticResource Sakura.Background}"/>
    <SolidColorBrush x:Key="SakuraBackgroundAltBrush" Color="{StaticResource Sakura.BackgroundAlt}"/>
    <SolidColorBrush x:Key="SakuraSurfaceBrush" Color="{StaticResource Sakura.Surface}"/>
    <SolidColorBrush x:Key="SakuraSurfaceSoftBrush" Color="{StaticResource Sakura.SurfaceSoft}"/>
    <SolidColorBrush x:Key="SakuraSurfaceStrongBrush" Color="{StaticResource Sakura.SurfaceStrong}"/>
    <SolidColorBrush x:Key="SakuraGlassHighlightBrush" Color="{StaticResource Sakura.GlassHighlight}"/>
    <SolidColorBrush x:Key="SakuraDangerBrush" Color="{StaticResource Sakura.Danger}"/>
    <SolidColorBrush x:Key="SakuraBranchBrush" Color="{StaticResource Sakura.Branch}"/>
    <SolidColorBrush x:Key="SakuraBorderBrush" Color="{StaticResource Sakura.Border}"/>
    <SolidColorBrush x:Key="SakuraBorderStrongBrush" Color="{StaticResource Sakura.BorderStrong}"/>
    <SolidColorBrush x:Key="SakuraTextBrush" Color="{StaticResource Sakura.Text}"/>
    <SolidColorBrush x:Key="SakuraTextMutedBrush" Color="{StaticResource Sakura.TextMuted}"/>
    <SolidColorBrush x:Key="SakuraTextSubtleBrush" Color="{StaticResource Sakura.TextSubtle}"/>
    <SolidColorBrush x:Key="SakuraPrimaryBrush" Color="{StaticResource Sakura.Primary}"/>
    <SolidColorBrush x:Key="SakuraPrimaryDeepBrush" Color="{StaticResource Sakura.PrimaryDeep}"/>
    <SolidColorBrush x:Key="SakuraPrimarySoftBrush" Color="{StaticResource Sakura.PrimarySoft}"/>
    <SolidColorBrush x:Key="SakuraSuccessBrush" Color="{StaticResource Sakura.Success}"/>
    <SolidColorBrush x:Key="SakuraWhiteBrush" Color="White"/>
    <SolidColorBrush x:Key="SakuraHoverOverlayBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="SakuraPressedOverlayBrush" Color="#24000000"/>

    <LinearGradientBrush x:Key="SakuraWindowGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF171116" Offset="0"/>
        <GradientStop Color="#FF21131B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SakuraGlassGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#CC2E1F28" Offset="0"/>
        <GradientStop Color="#A83D2532" Offset="0.52"/>
        <GradientStop Color="#8839222F" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SakuraGlassSoftGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B839222F" Offset="0"/>
        <GradientStop Color="#782E1F28" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SakuraPrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Sakura.PrimaryLight}" Offset="0"/>
        <GradientStop Color="{StaticResource Sakura.PrimaryDeep}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SakuraHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#663D2532" Offset="0"/>
        <GradientStop Color="#CC271B23" Offset="1"/>
    </LinearGradientBrush>

    <!-- Effects: keep blur restrained for WPF rendering performance. -->
    <DropShadowEffect x:Key="SakuraCardShadow"
                      Color="#CC000000"
                      BlurRadius="18"
                      ShadowDepth="4"
                      Opacity="0.28"/>
    <DropShadowEffect x:Key="SakuraRaisedShadow"
                      Color="#CC000000"
                      BlurRadius="30"
                      ShadowDepth="8"
                      Opacity="0.34"/>
    <DropShadowEffect x:Key="SakuraPrimaryShadow"
                      Color="#72ED3F82"
                      BlurRadius="18"
                      ShadowDepth="5"
                      Opacity="0.32"/>

    <CubicEase x:Key="SakuraEaseOut" EasingMode="EaseOut"/>
    <BackEase x:Key="SakuraSpring" Amplitude="0.22" EasingMode="EaseOut"/>

    <!-- Window and text -->
    <Style x:Key="SakuraWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource SakuraWindowGradient}"/>
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <Style x:Key="SakuraTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="31"/>
    </Style>
    <Style x:Key="SakuraHeading" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="SakuraBody" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextMutedBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="LineHeight" Value="18"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="SakuraEyebrow" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SakuraPrimaryBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- Card surface -->
    <Style x:Key="SakuraCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SakuraGlassGradient}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraGlassHighlightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource SakuraCardShadow}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>
    <Style x:Key="SakuraHeroCard" TargetType="Border" BasedOn="{StaticResource SakuraCard}">
        <Setter Property="Background" Value="{StaticResource SakuraHeroGradient}"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="CornerRadius" Value="22"/>
    </Style>

    <!-- Keyboard focus visual -->
    <Style x:Key="SakuraFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Margin="-3"
                            BorderBrush="{StaticResource SakuraPrimaryBrush}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Opacity="0.72"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Buttons. Motion is kept on transforms so layout does not reflow. -->
    <Style x:Key="SakuraButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SakuraSurfaceSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="13,7"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="MinWidth" Value="70"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="Lift" Y="0"/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True"/>
                                <Border x:Name="HoverOverlay" Background="{StaticResource SakuraHoverOverlayBrush}" CornerRadius="9" Opacity="0"/>
                                <Border x:Name="PressedOverlay" Background="{StaticResource SakuraPressedOverlayBrush}" CornerRadius="9" Opacity="0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16"/>
                                    <DoubleAnimation Storyboard.TargetName="Lift" Storyboard.TargetProperty="Y" To="-1" Duration="0:0:0.16" EasingFunction="{StaticResource SakuraEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16"/>
                                    <DoubleAnimation Storyboard.TargetName="Lift" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.16" EasingFunction="{StaticResource SakuraEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedOverlay" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraPrimaryButton" TargetType="Button" BasedOn="{StaticResource SakuraButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource SakuraPrimaryGradient}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Effect" Value="{StaticResource SakuraPrimaryShadow}"/>
    </Style>

    <Style x:Key="SakuraGhostButton" TargetType="Button" BasedOn="{StaticResource SakuraButton}">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Navigation button with a soft active state. Set Tag=True for the active item. -->
    <Style x:Key="SakuraNavButton" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextMutedBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="Indicator"
                                Width="3" Height="24"
                                HorizontalAlignment="Left"
                                Background="{StaticResource SakuraPrimaryBrush}"
                                CornerRadius="2"
                                Margin="-8,0,0,0"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform ScaleY="0.35"/></Border.RenderTransform>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SakuraSurfaceSoftBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SakuraPrimarySoftBrush}"/>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SakuraBorderStrongBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SakuraPrimaryDeepBrush}"/>
                            <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                            <Setter TargetName="Indicator" Property="RenderTransform">
                                <Setter.Value><ScaleTransform ScaleY="1"/></Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Inputs -->
    <Style x:Key="SakuraTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SakuraSurfaceSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="11,8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{StaticResource SakuraPrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource SakuraPrimarySoftBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SakuraPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.50"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box"
                                Width="16" Height="16"
                                Margin="0,0,7,0"
                                Background="{StaticResource SakuraSurfaceSoftBrush}"
                                BorderBrush="{StaticResource SakuraBorderStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Path x:Name="Check"
                                  Data="M 3 8 L 6.5 11.5 L 13 4.5"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Opacity="0"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource SakuraPrimaryBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource SakuraPrimaryBrush}"/>
                            <Setter TargetName="Check" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Page entrance: attach this storyboard to the Loaded event of a page root. -->
    <Storyboard x:Key="SakuraPageEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="0:0:0.22"
                         EasingFunction="{StaticResource SakuraEaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="8" To="0"
                         Duration="0:0:0.22"
                         EasingFunction="{StaticResource SakuraEaseOut}"/>
    </Storyboard>

    <!-- Slow left-to-right decorative drift. Use at most 6–8 petals and disable when reduced motion is enabled. -->
    <Storyboard x:Key="SakuraPetalDrift" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0.70" Duration="0:0:2" AutoReverse="True"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                         From="-40" To="1900" Duration="0:0:22"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(RotateTransform.Angle)"
                         From="0" To="720" Duration="0:0:22"/>
    </Storyboard>

    <!-- Shell surfaces used across Dashboard, Generate, JSON, Editor, Images, Tools, Help, Reports, Update, and Settings. -->
    <Style x:Key="SakuraGlassPanel" TargetType="Border" BasedOn="{StaticResource SakuraCard}">
        <Setter Property="Background" Value="{StaticResource SakuraGlassGradient}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraGlassHighlightBrush}"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="14"/>
    </Style>

    <Style x:Key="SakuraGlassPanelSoft" TargetType="Border" BasedOn="{StaticResource SakuraGlassPanel}">
        <Setter Property="Background" Value="{StaticResource SakuraGlassSoftGradient}"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <Style x:Key="SakuraTopBar" TargetType="Border" BasedOn="{StaticResource SakuraGlassPanel}">
        <Setter Property="Height" Value="62"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="14,0"/>
    </Style>

    <Style x:Key="SakuraSidebar" TargetType="Border" BasedOn="{StaticResource SakuraGlassPanel}">
        <Setter Property="Width" Value="104"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="SakuraWorkspace" TargetType="Border" BasedOn="{StaticResource SakuraGlassPanel}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="SakuraConsole" TargetType="Border" BasedOn="{StaticResource SakuraGlassPanel}">
        <Setter Property="MinHeight" Value="88"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style x:Key="SakuraInsetPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SakuraGlassSoftGradient}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style x:Key="SakuraStatusPill" TargetType="Border" BasedOn="{StaticResource SakuraInsetPanel}">
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SakuraSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource SakuraHeading}">
        <Setter Property="FontSize" Value="21"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="SakuraCaption" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextSubtleBrush}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="SakuraDangerButton" TargetType="Button" BasedOn="{StaticResource SakuraButton}">
        <Setter Property="Foreground" Value="{StaticResource SakuraDangerBrush}"/>
        <Setter Property="Background" Value="#18C93762"/>
        <Setter Property="BorderBrush" Value="#38C93762"/>
    </Style>

    <Style x:Key="SakuraIconButton" TargetType="Button" BasedOn="{StaticResource SakuraButton}">
        <Setter Property="MinWidth" Value="34"/>
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ComboBox and list styles keep native keyboard behavior while replacing the default Windows chrome. -->
    <Style x:Key="SakuraComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SakuraPrimarySoftBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SakuraPrimarySoftBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SakuraPrimaryDeepBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SakuraGlassSoftGradient}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SakuraComboBoxItem}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                                <ToggleButton Focusable="False"
                                              HorizontalAlignment="Right"
                                              Width="32"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" CornerRadius="0,10,10,0">
                                                <Path Width="8" Height="5" Stretch="Fill"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{StaticResource SakuraTextMutedBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               Focusable="False">
                            <Border Margin="0,5,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="320"
                                    Background="{StaticResource SakuraSurfaceStrongBrush}"
                                    BorderBrush="{StaticResource SakuraGlassHighlightBrush}"
                                    BorderThickness="1"
                                    CornerRadius="11"
                                    Padding="5"
                                    Effect="{StaticResource SakuraRaisedShadow}">
                                <ScrollViewer CanContentScroll="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SakuraPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraListBox" TargetType="ListBox">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Background" Value="#22FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="11"
                            SnapsToDevicePixels="True">
                        <ScrollViewer Padding="{TemplateBinding Padding}" Focusable="False">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <Border x:Name="Indicator" Width="3" HorizontalAlignment="Left" Background="{StaticResource SakuraPrimaryBrush}" Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#12ED3F82"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SakuraPrimarySoftBrush}"/>
                            <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource SakuraPrimaryDeepBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Foreground" Value="{StaticResource SakuraPrimaryGradient}"/>
        <Setter Property="Background" Value="{StaticResource SakuraPrimarySoftBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid ClipToBounds="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="999"/>
                        <Border x:Name="PART_Track" Background="Transparent"/>
                        <Border x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="999"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toggle switch: use a CheckBox with this style. -->
    <Style x:Key="SakuraToggleSwitch" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource SakuraTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource SakuraFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border x:Name="Track"
                                Grid.Column="1"
                                Width="38" Height="22"
                                CornerRadius="999"
                                Background="{StaticResource SakuraSurfaceSoftBrush}"
                                BorderBrush="{StaticResource SakuraBorderStrongBrush}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb"
                                     Width="16" Height="16"
                                     HorizontalAlignment="Left"
                                     Margin="2"
                                     Fill="White"
                                     Effect="{StaticResource SakuraCardShadow}">
                                <Ellipse.RenderTransform><TranslateTransform x:Name="ThumbMove"/></Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
	                            <Setter TargetName="Track" Property="Background" Value="{StaticResource SakuraPrimaryGradient}"/>
	                            <Setter TargetName="Track" Property="BorderBrush" Value="Transparent"/>
	                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
	                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SakuraSeparator" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource SakuraBorderBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}" Height="{TemplateBinding Height}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Static fallback branch for views that cannot host the animated SakuraBackdrop control. -->
    <DrawingBrush x:Key="SakuraBranchFallbackBrush"
                  Stretch="UniformToFill"
                  AlignmentX="Left"
                  AlignmentY="Top"
                  Viewbox="0,0,1180,500"
                  ViewboxUnits="Absolute"
                  Viewport="0,0,1,0.55"
                  ViewportUnits="RelativeToBoundingBox">
        <DrawingBrush.Drawing>
            <DrawingGroup Opacity="0.46">
                <GeometryDrawing Geometry="M -85,318 C 83,275 156,219 287,161 C 435,95 596,95 775,27">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource SakuraBranchBrush}" Thickness="17" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M 74,277 C 184,268 275,277 388,326">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource SakuraBranchBrush}" Thickness="9" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M 202,205 C 247,158 277,107 298,37 M 382,119 C 447,103 514,65 565,4 M 517,94 C 615,117 704,154 789,222 M 650,72 C 741,73 823,95 917,145">
                    <GeometryDrawing.Pen><Pen Brush="{StaticResource SakuraBranchBrush}" Thickness="7" StartLineCap="Round" EndLineCap="Round"/></GeometryDrawing.Pen>
                </GeometryDrawing>
                <GeometryDrawing Brush="#E8FF86B4" Geometry="M 112,250 C 121,238 136,239 142,252 C 133,265 119,267 112,250 Z M 232,179 C 242,165 258,168 264,181 C 254,194 240,195 232,179 Z M 420,101 C 430,87 446,90 451,104 C 441,117 427,117 420,101 Z M 643,124 C 654,109 670,113 675,127 C 664,140 650,140 643,124 Z M 824,92 C 835,78 851,82 856,96 C 845,109 831,109 824,92 Z"/>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Storyboard x:Key="SakuraCardEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.34" EasingFunction="{StaticResource SakuraEaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="12" To="0" Duration="0:0:0.34" EasingFunction="{StaticResource SakuraSpring}"/>
    </Storyboard>

    <Storyboard x:Key="SakuraToastEnter">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.28" EasingFunction="{StaticResource SakuraEaseOut}"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="28" To="0" Duration="0:0:0.32" EasingFunction="{StaticResource SakuraSpring}"/>
    </Storyboard>

    <Storyboard x:Key="SakuraPetalWindAlt" RepeatBehavior="Forever">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:1.3" Value="0.72"/>
            <EasingDoubleKeyFrame KeyTime="0:0:18" Value="0.58"/>
            <EasingDoubleKeyFrame KeyTime="0:0:24" Value="0"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)" From="-60" To="2050" Duration="0:0:24"/>
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)">
            <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:7" Value="70"/>
            <EasingDoubleKeyFrame KeyTime="0:0:14" Value="-18"/>
            <EasingDoubleKeyFrame KeyTime="0:0:24" Value="150"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(RotateTransform.Angle)" From="20" To="760" Duration="0:0:24"/>
    </Storyboard>

</ResourceDictionary>

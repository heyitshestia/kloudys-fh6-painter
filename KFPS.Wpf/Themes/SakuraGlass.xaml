<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="InkBrush" Color="#FF27212A" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="#FF756A73" />
    <SolidColorBrush x:Key="DimInkBrush" Color="#FFA1959D" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="PanelSoftBrush" Color="#FFFFF9FB" />
    <SolidColorBrush x:Key="PanelLiftBrush" Color="#FFFFEDF4" />
    <SolidColorBrush x:Key="ControlBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFF6B9E" />
    <SolidColorBrush x:Key="AccentDeepBrush" Color="#FFE9427F" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#55FF6B9E" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFE9D6DE" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FFFFDCE8" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FFE9427F" />

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFFFF" Offset="0" />
        <GradientStop Color="#FFFFFBFD" Offset="0.52" />
        <GradientStop Color="#FFFFF6F9" Offset="1" />
    </LinearGradientBrush>

    <Pen x:Key="SakuraTextureLinePen" Brush="#22B8175C" Thickness="1" />

    <DrawingBrush x:Key="AppTextureBrush"
                  TileMode="Tile"
                  Viewport="0,0,180,180"
                  ViewportUnits="Absolute"
                  Stretch="None"
                  Opacity="0.26">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Pen="{StaticResource SakuraTextureLinePen}">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M -10,148 C 36,124 78,135 114,104 S 158,70 194,46" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#1AFF6B9E">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="28,34" RadiusX="9" RadiusY="3" />
                            <EllipseGeometry Center="78,112" RadiusX="6" RadiusY="2" />
                            <EllipseGeometry Center="132,74" RadiusX="10" RadiusY="3" />
                            <EllipseGeometry Center="156,146" RadiusX="7" RadiusY="2.5" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#14E9427F">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="42,126" RadiusX="5" RadiusY="2" />
                            <EllipseGeometry Center="102,52" RadiusX="5" RadiusY="2" />
                            <EllipseGeometry Center="166,24" RadiusX="4" RadiusY="1.5" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
</ResourceDictionary>

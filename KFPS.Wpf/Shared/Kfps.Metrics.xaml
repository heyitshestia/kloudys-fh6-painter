<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Shell -->
    <sys:Double x:Key="Metric.WindowWidth">1548</sys:Double>
    <sys:Double x:Key="Metric.WindowHeight">970</sys:Double>
    <sys:Double x:Key="Metric.WindowMinWidth">1140</sys:Double>
    <sys:Double x:Key="Metric.WindowMinHeight">720</sys:Double>
    <sys:Double x:Key="Metric.OuterMargin">12</sys:Double>
    <sys:Double x:Key="Metric.TopBarHeight">60</sys:Double>
    <sys:Double x:Key="Metric.SidebarWidth">104</sys:Double>
    <sys:Double x:Key="Metric.ConsoleHeight">160</sys:Double>
    <sys:Double x:Key="Metric.UtilityRailWidth">276</sys:Double>
    <sys:Double x:Key="Metric.NavButtonHeight">46</sys:Double>
    <sys:Double x:Key="Metric.VersionPillWidth">244</sys:Double>
    <sys:Double x:Key="Metric.VersionPillHeight">32</sys:Double>

    <!-- Spacing -->
    <Thickness x:Key="Spacing.Outer">12</Thickness>
    <Thickness x:Key="Spacing.Page">14</Thickness>
    <Thickness x:Key="Spacing.Card">14</Thickness>
    <Thickness x:Key="Spacing.Hero">16</Thickness>
    <Thickness x:Key="Spacing.ControlHorizontal">12,0</Thickness>
    <Thickness x:Key="Spacing.FieldPadding">10,7</Thickness>
    <Thickness x:Key="Spacing.NavPadding">6</Thickness>
    <Thickness x:Key="Spacing.Console">12,8</Thickness>

    <!-- Corners -->
    <CornerRadius x:Key="Corner.Control">8</CornerRadius>
    <CornerRadius x:Key="Corner.Compact">10</CornerRadius>
    <CornerRadius x:Key="Corner.Card">12</CornerRadius>
    <CornerRadius x:Key="Corner.Hero">16</CornerRadius>
    <CornerRadius x:Key="Corner.Pill">16</CornerRadius>

    <!-- Typography -->
    <FontFamily x:Key="Font.Ui">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Console">Consolas</FontFamily>
    <sys:Double x:Key="Type.DashboardTitle">24</sys:Double>
    <sys:Double x:Key="Type.PageTitle">23</sys:Double>
    <sys:Double x:Key="Type.Hero">26</sys:Double>
    <sys:Double x:Key="Type.SectionTitle">18</sys:Double>
    <sys:Double x:Key="Type.CardTitle">16</sys:Double>
    <sys:Double x:Key="Type.Body">12</sys:Double>
    <sys:Double x:Key="Type.BodyCompact">11.5</sys:Double>
    <sys:Double x:Key="Type.Label">10.5</sys:Double>
    <sys:Double x:Key="Type.NavLabel">10</sys:Double>
    <sys:Double x:Key="Type.Console">11</sys:Double>

    <!-- Control sizes -->
    <sys:Double x:Key="Control.Height.Primary">34</sys:Double>
    <sys:Double x:Key="Control.Height.Dense">32</sys:Double>
    <sys:Double x:Key="Control.Height.Field">34</sys:Double>
    <sys:Double x:Key="Control.Height.ListRow">34</sys:Double>

    <!-- Focus visual -->
    <Style x:Key="KfpsFocusVisualStyle">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="-2"
                               RadiusX="10"
                               RadiusY="10"
                               Stroke="{DynamicResource FocusRingBrush}"
                               StrokeThickness="1"
                               StrokeDashArray="2 2"
                               SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

<Application x:Class="KFPS.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/SakuraGlass.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Compatibility aliases for the existing KFPS shell code. -->
            <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Sakura.Text}" />
            <SolidColorBrush x:Key="MutedInkBrush" Color="{StaticResource Sakura.TextMuted}" />
            <SolidColorBrush x:Key="DimInkBrush" Color="{StaticResource Sakura.TextSubtle}" />
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource Sakura.Surface}" />
            <SolidColorBrush x:Key="PanelSoftBrush" Color="{StaticResource Sakura.SurfaceSoft}" />
            <SolidColorBrush x:Key="PanelLiftBrush" Color="{StaticResource Sakura.PrimarySoft}" />
            <SolidColorBrush x:Key="ControlBrush" Color="{StaticResource Sakura.SurfaceStrong}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Sakura.Primary}" />
            <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource Sakura.PrimaryDeep}" />
            <SolidColorBrush x:Key="AccentGlowBrush" Color="#66ED3F82" />
            <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource Sakura.Border}" />
            <SolidColorBrush x:Key="ButtonHoverBrush" Color="#18FFFFFF" />
            <SolidColorBrush x:Key="ButtonPressedBrush" Color="#24000000" />
            <SolidColorBrush x:Key="LogInkBrush" Color="#FF9D2253" />
            <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource Sakura.Background}" Offset="0" />
                <GradientStop Color="{StaticResource Sakura.BackgroundAlt}" Offset="0.56" />
                <GradientStop Color="#FFFFD8E8" Offset="1" />
            </LinearGradientBrush>
            <DrawingBrush x:Key="AppTextureBrush" TileMode="Tile" Viewport="0,0,180,180" ViewportUnits="Absolute" Stretch="None" Opacity="0.18">
                <DrawingBrush.Drawing>
                    <GeometryDrawing Brush="#14ED3F82">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <EllipseGeometry Center="28,34" RadiusX="9" RadiusY="3" />
                                <EllipseGeometry Center="78,112" RadiusX="6" RadiusY="2" />
                                <EllipseGeometry Center="132,74" RadiusX="10" RadiusY="3" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            </Style>

            <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource SakuraBody}" />

            <Style x:Key="TinyLabel" TargetType="TextBlock" BasedOn="{StaticResource SakuraEyebrow}">
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="PageHeading" TargetType="TextBlock" BasedOn="{StaticResource SakuraTitle}">
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource SakuraHeading}">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource SakuraCard}" />
            <Style x:Key="TightCard" TargetType="Border" BasedOn="{StaticResource SakuraGlassPanelSoft}">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style TargetType="Button" BasedOn="{StaticResource SakuraButton}" />
            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SakuraPrimaryButton}" />
            <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource SakuraButton}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Height" Value="56" />
            </Style>

            <Style TargetType="TextBox" BasedOn="{StaticResource SakuraTextBox}" />
            <Style TargetType="ComboBox" BasedOn="{StaticResource SakuraComboBox}" />
            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource SakuraComboBoxItem}" />
            <Style TargetType="CheckBox" BasedOn="{StaticResource SakuraCheckBox}" />
            <Style TargetType="ListBox" BasedOn="{StaticResource SakuraListBox}" />
            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SakuraListBoxItem}" />
            <Style TargetType="ProgressBar" BasedOn="{StaticResource SakuraProgressBar}" />

            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                <Setter Property="Background" Value="{DynamicResource PanelSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

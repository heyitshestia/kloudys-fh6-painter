<Application x:Class="KFPS.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Kfps.Theme.NightBlossom.xaml" />
                <ResourceDictionary Source="Shared/Kfps.Metrics.xaml" />
                <ResourceDictionary Source="Shared/Kfps.Icons.xaml" />
                <ResourceDictionary Source="Shared/Kfps.Controls.xaml" />
                <ResourceDictionary Source="Shared/Kfps.AdditionalControls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <!-- Compatibility aliases for the production shell. -->
            <SolidColorBrush x:Key="InkBrush" Color="{DynamicResource Color.Text}" />
            <SolidColorBrush x:Key="MutedInkBrush" Color="{DynamicResource Color.Muted}" />
            <SolidColorBrush x:Key="DimInkBrush" Color="{DynamicResource Color.Subtle}" />
            <SolidColorBrush x:Key="PanelBrush" Color="{DynamicResource Color.Surface}" />
            <SolidColorBrush x:Key="PanelSoftBrush" Color="{DynamicResource Color.SurfaceSoft}" />
            <SolidColorBrush x:Key="PanelLiftBrush" Color="{DynamicResource Color.SurfaceStrong}" />
            <SolidColorBrush x:Key="ControlBrush" Color="{DynamicResource Color.SurfaceStrong}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource Color.Primary}" />
            <SolidColorBrush x:Key="AccentDeepBrush" Color="{DynamicResource Color.PrimaryDeep}" />
            <SolidColorBrush x:Key="AccentGlowBrush" Color="#66E94D94" />
            <SolidColorBrush x:Key="BorderBrushSoft" Color="{DynamicResource Color.Border}" />
            <SolidColorBrush x:Key="ButtonHoverBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="ButtonPressedBrush" Color="#28000000" />
            <SolidColorBrush x:Key="LogInkBrush" Color="{DynamicResource Color.Muted}" />
            <DrawingBrush x:Key="AppTextureBrush" TileMode="Tile" Viewport="0,0,180,180" ViewportUnits="Absolute" Stretch="None" Opacity="0.10">
                <DrawingBrush.Drawing>
                    <GeometryDrawing Brush="#18E94D94">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <EllipseGeometry Center="28,34" RadiusX="9" RadiusY="3" />
                                <EllipseGeometry Center="78,112" RadiusX="6" RadiusY="2" />
                                <EllipseGeometry Center="132,74" RadiusX="10" RadiusY="3" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Text}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
                <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            </Style>

            <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource KfpsBodyText}" />
            <Style x:Key="TinyLabel" TargetType="TextBlock" BasedOn="{StaticResource KfpsLabelText}">
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>
            <Style x:Key="PageHeading" TargetType="TextBlock" BasedOn="{StaticResource KfpsPageTitleText}">
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>
            <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource KfpsSectionTitleText}">
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource KfpsCardStyle}" />
            <Style x:Key="TightCard" TargetType="Border" BasedOn="{StaticResource KfpsSoftCardStyle}">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
            <Style x:Key="SakuraCard" TargetType="Border" BasedOn="{StaticResource KfpsCardStyle}" />
            <Style x:Key="SakuraGlassPanel" TargetType="Border" BasedOn="{StaticResource KfpsCardStyle}" />
            <Style x:Key="SakuraSidebar" TargetType="Border" BasedOn="{StaticResource KfpsSidebarStyle}" />
            <Style x:Key="SakuraTopBar" TargetType="Border" BasedOn="{StaticResource KfpsTopBarStyle}" />
            <Style x:Key="SakuraWorkspace" TargetType="Border" BasedOn="{StaticResource KfpsCardStyle}" />
            <Style x:Key="SakuraConsole" TargetType="Border" BasedOn="{StaticResource KfpsConsolePanelStyle}" />

            <Style TargetType="Button" BasedOn="{StaticResource KfpsGhostButtonStyle}" />
            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource KfpsPrimaryButtonStyle}" />
            <Style x:Key="NavButton" TargetType="ToggleButton" BasedOn="{StaticResource KfpsNavButtonStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="Height" Value="{DynamicResource Metric.NavButtonHeight}" />
            </Style>

            <Style TargetType="TextBox" BasedOn="{StaticResource KfpsTextBoxStyle}" />
            <Style TargetType="ComboBox" BasedOn="{StaticResource KfpsComboBoxStyle}" />
            <Style TargetType="CheckBox" BasedOn="{StaticResource KfpsCheckBoxStyle}" />
            <Style TargetType="ListBox" BasedOn="{StaticResource KfpsListBoxStyle}" />
            <Style TargetType="ProgressBar" BasedOn="{StaticResource KfpsProgressBarStyle}" />

            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{DynamicResource Text}" />
                <Setter Property="Background" Value="{DynamicResource GlassPanelSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

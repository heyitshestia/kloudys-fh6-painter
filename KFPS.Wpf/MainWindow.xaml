                                <Border Background="{DynamicResource PanelLiftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="16,12">
                                    <StackPanel>
                                        <TextBlock Text="Preview" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="This is exactly what gets saved." Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                </Border>
                                <TextBox x:Name="ReportPreviewTextBox"
                                         Grid.Row="1"
                                         Text="Press Preview report to render the markdown here."
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource InkBrush}"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="12"
                                         Padding="16" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="SettingsCenterView" Visibility="Collapsed" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
	                    <DockPanel>
	                        <StackPanel>
	                            <TextBlock Text="Checks and preferences" FontSize="24" FontWeight="SemiBold" />
	                        </StackPanel>
	                    </DockPanel>
                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="16">
                            <StackPanel>
	                                <TextBlock Text="Bundle checks and updates" Style="{StaticResource SectionTitle}" />
	                                <TextBlock Text="Verify the bundled runtime or update app files. A complete native package should not need external Python." Style="{StaticResource MutedText}" Margin="0,0,0,14" />
	                                <Button Content="Check bundled Python" Click="SetupPython" Padding="16,8" />
	                                <Button Content="Check dependencies" Click="InstallDependencies" Padding="16,8" />
	                                <Button Content="Update from GitHub" Style="{StaticResource PrimaryButton}" Click="UpdateFromGitHub" Padding="16,8" />
	                                <Border Background="{DynamicResource PanelLiftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,12,0,0">
	                                    <TextBlock Text="If generation, previews, editor launch, or import/export fail, run the checks here. Missing bundled files usually mean the package should be re-extracted." Style="{StaticResource MutedText}" />
	                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Preferences" Style="{StaticResource SectionTitle}" />
	                                <TextBlock Text="Keep defaults unless you are intentionally testing generator settings." Style="{StaticResource MutedText}" Margin="0,0,0,14" />
                                <CheckBox x:Name="ManualOverridesCheckBox"
	                                          Content="Enable manual generator overrides"
                                          Checked="ManualOverridesChanged"
                                          Unchecked="ManualOverridesChanged" />
	                                <TextBlock Text="Shows advanced controls for resolution, sample counts, and seed." Style="{StaticResource MutedText}" Margin="22,-4,0,10" />
                                <CheckBox Content="Blue Terminal dial-up sound" />
                                <TextBlock Text="Only affects the retro terminal theme." Style="{StaticResource MutedText}" Margin="22,-4,0,10" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Current app root" Style="{StaticResource SectionTitle}" />
                                    <TextBox x:Name="AppRootText" IsReadOnly="True" TextWrapping="Wrap" />
                                </StackPanel>
                                <UniformGrid Grid.Column="2" Columns="2" Rows="2" VerticalAlignment="Center">
	                                    <Button Content="Runtime" Click="OpenRuntimeFolder" Padding="12,7" />
	                                    <Button Content="JSON folders" Click="OpenJsonFolders" Padding="12,7" />
	                                    <Button Content="Generated" Click="OpenGeneratedFolder" Padding="12,7" />
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <Border x:Name="InspectorPanel" Grid.Row="1" Grid.Column="3" Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Margin="0,10,0,10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="185" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="INSPECTOR" Style="{StaticResource TinyLabel}" />
                <Border Grid.Row="1" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="2" Margin="0,10,0,16">
                    <Grid>
                        <Image x:Name="SourcePreviewImage" Stretch="Uniform" Margin="8" />
                        <TextBlock x:Name="SourcePreviewPlaceholder" Text="Source preview" Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <DockPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="RECENT" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left" />
                    <Button Content="Refresh" DockPanel.Dock="Right" Click="RefreshPreviews" Padding="10,5" />
                </DockPanel>
                <ListBox x:Name="RecentFilesList" Grid.Row="3" SelectionChanged="RecentFilesList_SelectionChanged" />
            </Grid>
        </Border>

	        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="10">
	            <Grid>
	                <Grid.ColumnDefinitions>
	                    <ColumnDefinition Width="*" />
	                    <ColumnDefinition Width="Auto" />
	                </Grid.ColumnDefinitions>
	                <TextBox x:Name="LogBox"
	                         IsReadOnly="True"
	                         AcceptsReturn="True"
	                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Hidden"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Mono, Consolas"
	                         FontSize="12"
	                         Background="#FFFFFFFF"
	                         Margin="0,0,10,0" />
	                <Button Grid.Column="1" Content="Clear" Click="ClearLog" Padding="12,6" VerticalAlignment="Top" />
	            </Grid>
	        </Border>

        <Grid x:Name="FirstLaunchOverlay"
              Grid.RowSpan="3"
              Grid.ColumnSpan="4"
              Panel.ZIndex="100"
              Visibility="Collapsed"
              Background="#99FFFFFF">
            <Border Width="620"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <StackPanel>
	                    <TextBlock Text="KFPS first launch check" FontSize="24" FontWeight="SemiBold" />
	                    <TextBlock Text="KFPS includes its own Python runtime and backend packages. This check confirms the bundle is complete before launching the workspace." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,18" />
	                    <Border Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,16">
	                        <TextBlock x:Name="FirstLaunchStatusText" Text="Checking bundled runtime..." Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
	                        <Button x:Name="FirstLaunchPythonButton" Content="Check Python" Click="FirstLaunchInstallPython" Padding="14,10" />
	                        <Button x:Name="FirstLaunchDepsButton" Grid.Column="2" Content="Check dependencies" Click="FirstLaunchInstallDependencies" Padding="14,10" />
                        <Button x:Name="FirstLaunchLaunchButton" Grid.Column="4" Content="Launch" Style="{StaticResource PrimaryButton}" Click="FirstLaunchVerifyAndLaunch" Padding="14,10" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

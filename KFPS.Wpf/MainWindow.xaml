<Window x:Class="KFPS.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KFPS - Kloudy's Forza Painter Suite"
        Width="1560"
        Height="975"
        MinWidth="1380"
        MinHeight="865"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="126" />
            <ColumnDefinition Width="310" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="314" />
        </Grid.ColumnDefinitions>

        <Canvas IsHitTestVisible="False" Panel.ZIndex="-1">
            <Ellipse Width="90" Height="34" Fill="#33FF8FB5" Canvas.Left="94" Canvas.Top="-8" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="-24" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="42" Height="16" Fill="#44FF9FBE" Canvas.Left="128" Canvas.Top="26" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="34" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="120" Height="44" Fill="#28FF7EAD" Canvas.Right="18" Canvas.Bottom="8" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="-18" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="54" Height="18" Fill="#33FF8FB5" Canvas.Right="138" Canvas.Top="74" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="22" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <Border Grid.Row="0" Grid.ColumnSpan="4" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="assets/kfps-logo.png" Width="26" Height="26" Margin="0,0,10,0" />
                    <TextBlock Text="KFPS" FontSize="18" FontWeight="SemiBold" TextWrapping="NoWrap" VerticalAlignment="Center" />
                    <Border Width="1" Height="20" Background="{DynamicResource BorderBrushSoft}" Margin="12,0" />
                    <TextBlock x:Name="PageTitle" Text="Dashboard" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MutedInkBrush}" TextWrapping="NoWrap" VerticalAlignment="Center" />
                    <TextBlock Text="  /  " Foreground="{DynamicResource DimInkBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText" Text="Ready" Style="{StaticResource MutedText}" FontSize="12" TextWrapping="NoWrap" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="THEME" Style="{StaticResource TinyLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="ThemeComboBox" Width="204" SelectionChanged="ThemeComboBox_SelectionChanged" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Margin="0,10,10,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <Button Style="{StaticResource NavButton}" Click="ShowDashboard" ToolTip="Dashboard">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⌂" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Home" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowGenerate" ToolTip="Generate Final Vinyl">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="◆" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Generate" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowImportExport" ToolTip="Import / Export JSON">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⇄" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="JSON" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowEditor" ToolTip="Editor">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="✎" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Editor" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowImageTools" ToolTip="Image Tools">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="▧" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Images" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowTools" ToolTip="Tools">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⚒" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Tools" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowTutorial" ToolTip="Tutorial">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="?" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Help" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowBugReports" ToolTip="Bug Reports">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="!" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Reports" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowSettings" ToolTip="Settings">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="18" TextAlignment="Center" />
                            <TextBlock Text="Settings" FontSize="10" TextAlignment="Center" Foreground="{DynamicResource MutedInkBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button Grid.Row="1" Style="{StaticResource NavButton}" Click="OpenAppRoot" ToolTip="Open app root">
                    <TextBlock Text="↗" FontSize="18" TextAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <Border x:Name="WorkflowPanel" Grid.Row="1" Grid.Column="1" Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Margin="0,10,10,10" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="WorkflowKicker" Text="CREATE" Style="{StaticResource TinyLabel}" />
                    <TextBlock x:Name="WorkflowTitle" Text="Source and run controls" FontSize="20" FontWeight="SemiBold" Margin="0,3,0,12" />
                </StackPanel>

                <Grid Grid.Row="1" x:Name="DashboardView" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="KFPS workspace" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="A single control surface for generating, hand-editing, importing, exporting, and troubleshooting vinyl JSONs." Style="{StaticResource MutedText}" />
                        <Button Content="Start with Generate" Style="{StaticResource PrimaryButton}" Click="ShowGenerate" Margin="0,16,0,8" />
                        <Button Content="Open Editor" Click="StartFabricEditor" />
                        <Button Content="Browse JSON" Click="ChooseJsonFile" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" x:Name="GenerateView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
	                    <StackPanel>
	                        <TextBlock Text="Source" Style="{StaticResource TinyLabel}" />
	                        <Button Content="Choose source image(s)" Style="{StaticResource PrimaryButton}" Click="ChooseSourceImage" Margin="0,6,0,8" />
	                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Preset" Style="{StaticResource TinyLabel}" />
                        <ComboBox x:Name="PresetComboBox" Grid.Row="1" SelectedIndex="0" Margin="0,6,0,10" SelectionChanged="PresetComboBox_SelectionChanged">
                            <ComboBoxItem Content="1. Shaded Character Art" />
                            <ComboBoxItem Content="2. Flat / Logo Colors" />
                            <ComboBoxItem Content="3. Gradients and Soft Art" />
                        </ComboBox>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Layers" Style="{StaticResource TinyLabel}" />
                                <ComboBox x:Name="LayerComboBox" SelectedIndex="3" Margin="0,6,0,0" SelectionChanged="LayerComboBox_SelectionChanged" MouseDoubleClick="LayerComboBox_MouseDoubleClick" ToolTip="Double-click to add a custom layer count.">
                                    <ComboBoxItem Content="500" />
                                    <ComboBoxItem Content="1000" />
                                    <ComboBoxItem Content="1500" />
                                    <ComboBoxItem Content="2000" />
                                    <ComboBoxItem Content="2500" />
                                    <ComboBoxItem Content="3000" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="Options" Style="{StaticResource TinyLabel}" Margin="0,0,0,8" />
                        <CheckBox x:Name="EdgeRepairCheckBox" Content="Edge Repair" IsChecked="False" />
                        <CheckBox x:Name="DetailHeatmapCheckBox" Content="Automatic Detail Heatmap" />
                        <CheckBox x:Name="LumaPrepCheckBox" Content="Luma Prep" />
                        <CheckBox x:Name="SampleBoostCheckBox" Content="2x Mode" />
                        <TextBlock Text="Final checkpoints" Style="{StaticResource TinyLabel}" Margin="0,12,0,6" />
                        <TextBox x:Name="FinalCheckpointsTextBox" Text="500,1000,1250,1500,2000,2500,3000" />
                    </StackPanel>
                    <StackPanel Grid.Row="3">
                        <Button x:Name="GenerateButton" Content="Generate Final Vinyl" Style="{StaticResource PrimaryButton}" Click="StartNativeGeneration" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="HeatmapToggleButton" Content="Preview Heatmap" Click="ToggleHeatmapPreview" />
                            <Button x:Name="StopButton" Grid.Column="2" Content="Stop" Click="StopNativeGeneration" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" x:Name="ImportExportView" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Import generated, editor, or exported JSONs. Export editable game groups." Style="{StaticResource MutedText}" />
                        <TextBlock Text="Game" Style="{StaticResource TinyLabel}" Margin="0,16,0,6" />
                        <ComboBox x:Name="TransferGameComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="FH6" />
                            <ComboBoxItem Content="FH5" />
                            <ComboBoxItem Content="FM8" />
                        </ComboBox>
                        <TextBlock Text="Loaded template / group layers" Style="{StaticResource TinyLabel}" Margin="0,12,0,6" />
	                        <TextBox x:Name="TransferLayerCountTextBox" Text="3000" Height="42" Padding="8,7" VerticalContentAlignment="Center" ToolTip="For import: loaded template layer count. For export: visible layer count of the open group." />
                        <TextBlock Text="JSON source" Style="{StaticResource TinyLabel}" Margin="0,12,0,6" />
                        <ComboBox x:Name="JsonSourceComboBox" SelectedIndex="0" SelectionChanged="JsonSourceComboBox_SelectionChanged">
                            <ComboBoxItem Content="Generated finals" />
                            <ComboBoxItem Content="Editor exports" />
                            <ComboBoxItem Content="Exported game JSONs" />
                        </ComboBox>
                        <Button Content="Refresh browser" Style="{StaticResource PrimaryButton}" Click="RefreshJsonBrowser" Margin="0,16,0,8" />
                        <Button Content="Open selected source folder" Click="OpenSelectedJsonSourceFolder" Margin="0,0,0,8" />
                        <Button Content="Browse JSON manually..." Click="ChooseJsonFile" Margin="0,0,0,8" />
                        <TextBox x:Name="SelectedJsonText" Text="No JSON selected yet." IsReadOnly="True" Height="44" TextWrapping="Wrap" />
                        <CheckBox x:Name="TransferClearUnusedCheckBox" Content="Clear unused template layers before trimming" IsChecked="True" Margin="0,16,0,8" />
                        <Button x:Name="ImportJsonButton" Content="Import JSON" Style="{StaticResource PrimaryButton}" Click="StartNativeImport" />
                        <Button x:Name="ExportJsonButton" Content="Export JSON" Click="StartNativeExport" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" x:Name="EditorView" Visibility="Collapsed">
                    <StackPanel>
                        <Button Content="Open Editor" Style="{StaticResource PrimaryButton}" Click="StartFabricEditor" Margin="0,16,0,8" />
                        <Button Content="Refresh editor workspace" Click="RefreshEditorWorkspace" />
                        <Button Content="Projects folder" Click="OpenEditorProjectsFolder" />
                        <Button Content="Editor app folder" Click="OpenEditorFolder" />
                    </StackPanel>
                </Grid>

	                <Grid Grid.Row="1" x:Name="ImageToolsView" Visibility="Collapsed">
	                    <StackPanel>
	                        <Button Content="Choose image" Style="{StaticResource PrimaryButton}" Click="ChooseSourceImage" Margin="0,16,0,8" />
	                        <Button Content="Refresh report" Click="RefreshImageReport" />
	                        <TextBlock Text="Same-aspect targets" Style="{StaticResource TinyLabel}" Margin="0,18,0,8" />
	                        <TextBlock Text="1 MP  1000×1000&#10;2 MP  1414×1414&#10;4 MP  2000×2000&#10;6 MP  2450×2450" Style="{StaticResource MutedText}" />
	                    </StackPanel>
	                </Grid>

	                <Grid Grid.Row="1" x:Name="ToolsView" Visibility="Collapsed">
	                    <StackPanel>
	                        <TextBlock Text="Browser-based helpers for source prep." Style="{StaticResource MutedText}" TextWrapping="Wrap" />
	                        <Button Content="Background remover" Style="{StaticResource PrimaryButton}" Click="OpenBackgroundRemover" Margin="0,16,0,8" />
	                        <Button Content="2x / 4x browser upscaler" Click="OpenBrowserUpscaler" Margin="0,0,0,8" />
	                        <Button Content="Resize / compress image" Click="OpenSquoosh" />
	                    </StackPanel>
	                </Grid>

	                <Grid Grid.Row="1" x:Name="TutorialView" Visibility="Collapsed">
                    <StackPanel>
                        <TextBox x:Name="TutorialSearchTextBox"
                                 TextChanged="TutorialSearchTextChanged"
                                 Margin="0,16,0,12"
                                 ToolTip="Search help topics" />
                        <Button x:Name="HelpTopicWorkflow" Content="Start here" Tag="workflow" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicGenerate" Content="Generate vinyls" Tag="generate" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicImages" Content="Image preparation" Tag="images" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicJson" Content="JSON browser" Tag="json" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicEditor" Content="Editor basics" Tag="editor" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicTransfer" Content="Import / Export" Tag="import" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicReports" Content="Bug reports" Tag="reports" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicSetup" Content="Checks and updates" Tag="setup" Click="ShowTutorialTopic" />
                        <Button x:Name="HelpTopicTroubleshooting" Content="Troubleshooting" Tag="troubleshooting" Click="ShowTutorialTopic" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" x:Name="BugReportsView" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="{DynamicResource PanelLiftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,16,0,12">
                            <TextBlock Text="Use the main panel to write details, preview exactly what will be saved, then save a markdown report into runtime/bug-reports." Style="{StaticResource MutedText}" />
                        </Border>
                        <Button Content="Open saved reports" Click="OpenReportsFolder" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" x:Name="SettingsView" Visibility="Collapsed">
                    <StackPanel>
	                        <Border Background="{DynamicResource PanelLiftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,16,0,12">
	                            <TextBlock Text="The native package includes its own Python runtime and backend dependencies. Use Settings to verify the bundle or update app files." Style="{StaticResource MutedText}" />
                        </Border>
	                        <Button Content="Open runtime folder" Click="OpenRuntimeFolder" />
	                        <Button Content="Open JSON folders" Click="OpenJsonFolders" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="DashboardWideView"
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Visibility="Collapsed"
                Background="{DynamicResource ControlBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,10,10,10"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

	                <StackPanel>
	                    <TextBlock Text="Welcome to KFPS" FontSize="26" FontWeight="SemiBold" />
	                    <TextBlock Text="Generate vinyls, refine them by hand, import JSONs into the game, export editable work, and keep projects organized from one focused native app." Style="{StaticResource MutedText}" MaxWidth="980" />
	                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0">
                        <StackPanel>
	                            <TextBlock Text="1. Create or select a JSON" Style="{StaticResource SectionTitle}" />
	                            <TextBlock Text="Start from a source image, a generated checkpoint, an editor export, or an exported game JSON." Style="{StaticResource MutedText}" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Generate tab" Style="{StaticResource PrimaryButton}" Click="ShowGenerate" />
                                <Button Content="Browse JSON" Click="ChooseJsonFile" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="2. Edit by hand" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Use the external vinyl editor for scratch builds, cleanup, source overlays, snapping, groups, masks, text, pixel art, colors, and exports." Style="{StaticResource MutedText}" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Open editor" Style="{StaticResource PrimaryButton}" Click="StartFabricEditor" />
                                <Button Content="Projects" Click="OpenEditorProjectsFolder" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource Card}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="3. Import or export" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Import selected JSONs into the loaded template, export editable game groups, and keep generated, editor, and exported folders separated." Style="{StaticResource MutedText}" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Transfer tab" Style="{StaticResource PrimaryButton}" Click="ShowImportExport" />
                                <Button Content="Runtime" Click="OpenRuntimeFolder" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0" Padding="0" CornerRadius="10" BorderThickness="2">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="KofiRimBrush" Color="#FFFF6B9E" />
                        </Border.BorderBrush>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetName="KofiRimBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#FFE9427F"
                                                        Duration="0:0:1.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Border.Effect>
                            <DropShadowEffect Color="#FFFF6B9E" BlurRadius="18" ShadowDepth="0" Opacity="0.22" />
                        </Border.Effect>
                        <Border Background="#FFFFE3EE" CornerRadius="8" Padding="18">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="720">
                                    <TextBlock Text="HELLOOO!" FontSize="30" FontWeight="Bold" TextAlignment="Center" Foreground="#FFB8175C" />
	                                    <TextBlock Text="If KFPS saved you time or helped finish a vinyl, a small tip is always appreciated." FontSize="14" TextAlignment="Center" Foreground="#FF6B2D48" Margin="0,5,0,14" />
	                                    <Button Content="Open Ko-fi" Style="{StaticResource PrimaryButton}" Click="OpenKofi" HorizontalAlignment="Center" Padding="24,9" />
	                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource Card}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="JSON folders" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Open the folder that contains generated finals, editor exports, and exported JSONs for import." Style="{StaticResource MutedText}" />
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
	                                <Button Content="Open JSON folders" Style="{StaticResource PrimaryButton}" Click="OpenJsonFolders" />
	                            </StackPanel>
	                        </StackPanel>
	                    </Border>
	                </Grid>
	            </Grid>
        </Border>

        <Grid x:Name="CenterHost" Grid.Row="1" Grid.Column="2" Margin="0,10,10,10">
            <Border x:Name="DashboardCenterView" Visibility="Collapsed" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Welcome to KFPS" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Create, edit, import, and export Forza vinyl JSONs from one focused workspace." Style="{StaticResource MutedText}" />
                    </StackPanel>
                    <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="0,18,0,18">
                        <Border Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="18" Margin="0,0,10,10">
                            <StackPanel>
                                <TextBlock Text="Generate Final Vinyl" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Image to vinyl with presets, source checks, and checkpoints." Style="{StaticResource MutedText}" />
                                <Button Content="Open Generate" Style="{StaticResource PrimaryButton}" Click="ShowGenerate" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="18" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Editor" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Hand edit generated, exported, or editor JSONs with overlays and snapping." Style="{StaticResource MutedText}" />
                                <Button Content="Open Editor" Style="{StaticResource PrimaryButton}" Click="StartFabricEditor" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="18" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Import JSON" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Pick generated, editor, or exported JSONs." Style="{StaticResource MutedText}" />
                                <Button Content="Browse JSON" Click="ChooseJsonFile" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource PanelSoftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Quick Status" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Dependencies ready&#10;Runtime logs available&#10;Updates through GitHub helper" Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Border Grid.Row="2" Background="{DynamicResource PanelLiftBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="10">
                        <TextBlock Text="Tip: use the left rail for workflows, then work left-to-right inside each page." Style="{StaticResource MutedText}" />
                    </Border>
                </Grid>
            </Border>

